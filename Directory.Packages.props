    <PackageVersion Include="Aspire.Hosting.Azure.AppService" Version="13.4.6" />
    <PackageVersion Include="Aspire.Hosting.Azure.Functions" Version="13.4.6" />
    <PackageVersion Include="Aspire.Hosting.Azure.Sql" Version="13.4.6" />
    <PackageVersion Include="Aspire.Hosting.Azure.Storage" Version="13.1.0" />
    <PackageVersion Include="Aspire.Microsoft.Data.SqlClient" Version="13.4.6" />
    <PackageVersion Include="AngleSharp" Version="1.5.0" />
    <PackageVersion Include="Azure.Identity" Version="1.18.0" />
    <PackageVersion Include="Azure.Monitor.OpenTelemetry.AspNetCore" Version="1.4.0" />
    <PackageVersion Include="Blazor.LocalStorage.WebAssembly" Version="9.0.1" />
