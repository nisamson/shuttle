<Project>
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <EntityFrameworkVersion>10.0.9</EntityFrameworkVersion>
    <MicrosoftIdentityWebVersion>4.12.0</MicrosoftIdentityWebVersion>
    <FluentUIVersion>5.0.0-rc.4-26180.1</FluentUIVersion>
    <OpenTelemetryVersion>1.15.3</OpenTelemetryVersion>
  </PropertyGroup>
  <ItemGroup>
    <PackageVersion Include="AccessibleColors" Version="1.0.10" />
    <PackageVersion Include="Aspire.Azure.Storage.Blobs" Version="13.1.0" />
