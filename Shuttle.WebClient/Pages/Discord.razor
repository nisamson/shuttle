@page "/debug/discord"
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@inject IWebAssemblyHostEnvironment Env

<PageTitle>Discord Lookup</PageTitle>

@if (Env.IsDevelopment()) {
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
        <h1>Discord Lookup</h1>
        <AuthorizeView>
            <Authorized>
                <p>
                    Scrapes a forum member's profile page on the server via
                    <code>GET /debug/users/{userId}/discord</code> and shows the Discord username listed on it.
                </p>

                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8"
                             VerticalAlignment="VerticalAlignment.Center">
                    <FluentTextInput TextInputType="TextInputType.Number" @bind-Value="UserIdText"
                                     Placeholder="Forum user id" @onkeydown="OnKeyDown"/>
                    <FluentButton Appearance="ButtonAppearance.Primary" OnClick="LookupAsync"
                                  Disabled="@(Loading || ParsedUserId is null)">
                        Look up
                    </FluentButton>
                </FluentStack>

                @if (Loading) {
                    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8"
                                 VerticalAlignment="VerticalAlignment.Center">
                        <FluentSpinner/>
                        <FluentText>Looking up Discord username…</FluentText>
                    </FluentStack>
                } else if (Error is not null) {
                    <FluentMessageBar Intent="MessageBarIntent.Error" Title="Lookup failed">
                        @Error
                    </FluentMessageBar>
                } else if (Result is not null) {
                    @if (Result.DiscordUsername is { Length: > 0 } username) {
                        <FluentMessageBar Intent="MessageBarIntent.Success"
                                          Title="@($"Discord username for user {Result.UserId}")">
                            @username
                        </FluentMessageBar>
                    } else {
                        <FluentMessageBar Intent="MessageBarIntent.Info"
                                          Title="@($"No Discord username for user {Result.UserId}")">
                            The member's forum profile does not list a Discord username.
                        </FluentMessageBar>
                    }
                }
            </Authorized>
            <NotAuthorized>
                <p>Not logged in.</p>
            </NotAuthorized>
        </AuthorizeView>
    </FluentStack>
} else {
    <p>This page is only available in the development environment.</p>
}
