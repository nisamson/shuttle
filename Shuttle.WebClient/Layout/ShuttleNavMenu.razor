@using Shuttle.WebClient.Models
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@inject IWebAssemblyHostEnvironment Env
<FluentNav Style="height: 100%;">
    <FluentNavItem Href="@Routes.Home" Match="NavLinkMatch.All" IconRest="@(new Icons.Regular.Size20.Home())">Home</FluentNavItem>
    <FluentDivider/>
    <AuthorizeView>
        <Authorized>
            <FluentNavItem OnClick="BeginLogout" IconRest="@(new Icons.Regular.Size20.SignOut())">Logout</FluentNavItem>
        </Authorized>
        <NotAuthorized>
            <FluentNavItem OnClick="BeginLogin" IconRest="@(new Icons.Regular.Size20.PersonArrowRight())">Login</FluentNavItem>
        </NotAuthorized>
    </AuthorizeView>
    <AuthorizeView Roles="@RoleNames.Admin">
        <Authorized>
            <FluentNavCategory Title="Admin" IconRest="@(new Icons.Regular.Size20.Shield())">
                <FluentNavItem Href="@Routes.Admin.Hello" Match="NavLinkMatch.All" IconRest="@(new Icons.Regular.Size20.Cloud())">API Check</FluentNavItem>
            </FluentNavCategory>
        </Authorized>
    </AuthorizeView>
    @if (Env.IsDevelopment()) {
        <FluentNavCategory Title="Debug" IconRest="@(new Icons.Regular.Size20.Bug())">
            <FluentNavItem Href="@Routes.Debug.Claims" Match="NavLinkMatch.All" IconRest="@(new Icons.Regular.Size20.Key())">Claims</FluentNavItem>
            <FluentNavItem Href="@Routes.Debug.Roles" Match="NavLinkMatch.All" IconRest="@(new Icons.Regular.Size20.PersonBoard())">Roles</FluentNavItem>
        </FluentNavCategory>
    }
    <FluentNavItem Href="@Routes.Articles.Blogs" Match="NavLinkMatch.All" IconRest="@(new Icons.Regular.Size20.News())">Blogs</FluentNavItem>
    <FluentNavCategory Title="Legal" IconRest="@(new Icons.Regular.Size20.Gavel())">
        <FluentNavItem Href="@Routes.Privacy" Match="NavLinkMatch.All" IconRest="@(new Icons.Regular.Size20.ShieldKeyhole())">Privacy Policy</FluentNavItem>
    </FluentNavCategory>
</FluentNav>