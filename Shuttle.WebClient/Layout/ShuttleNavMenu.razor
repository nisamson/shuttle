@using Shuttle.WebClient.Models
<MudNavMenu>
    <MudNavLink Icon="@Icons.Material.Filled.Home" Href="@Routes.Home" Match="NavLinkMatch.All">Home</MudNavLink>
    <MudDivider FlexItem="true"/>
    <AuthorizeView>
        <Authorized>
            <MudNavLink Icon="@Icons.Material.Filled.Logout" Href="@Routes.Authentication.Logout" Match="NavLinkMatch.All">Logout</MudNavLink>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Icon="@Icons.Material.Filled.Login" Href="@Routes.Authentication.Login" Match="NavLinkMatch.All">Login</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
    <MudNavGroup Title="Legal" Icon="@Icons.Material.Filled.Gavel">
        <MudNavLink Icon="@Icons.Material.Filled.PrivacyTip" Href="@Routes.Privacy" Match="NavLinkMatch.All">Privacy Policy</MudNavLink>
    </MudNavGroup>
</MudNavMenu>