@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Shuttle.WebClient.Models
<FluentNavMenu Expanded="@Expanded" Width="250" Title="Navigation menu">
    <FluentNavLink Href="@Routes.Home" Match="NavLinkMatch.All" Icon="@(new Icons.Regular.Size20.Home())">Home</FluentNavLink>
    <FluentDivider/>
    <AuthorizeView>
        <Authorized>
            <FluentNavLink OnClick="BeginLogOut" Icon="@(new Icons.Regular.Size20.SignOut())">Logout</FluentNavLink>
        </Authorized>
        <NotAuthorized>
            <FluentNavLink Href="@Routes.Authentication.Login" Match="NavLinkMatch.All" Icon="@(new Icons.Regular.Size20.PersonArrowRight())">Login</FluentNavLink>
        </NotAuthorized>
    </AuthorizeView>
    <FluentNavGroup Title="Legal" Icon="@(new Icons.Regular.Size20.Gavel())">
        <FluentNavLink Href="@Routes.Privacy" Match="NavLinkMatch.All" Icon="@(new Icons.Regular.Size20.ShieldKeyhole())">Privacy Policy</FluentNavLink>
    </FluentNavGroup>
</FluentNavMenu>