@using Shuttle.WebClient.Components
@using Shuttle.WebClient.Components.Dev
@using Shuttle.WebClient.Components.Options
@inherits LayoutComponentBase
@* Required *@
<MudThemeProvider IsDarkMode="@Options.DarkMode"/>
<MudPopoverProvider/>

@* Needed for dialogs *@
<MudDialogProvider/>

@* Needed for snackbars *@
<MudSnackbarProvider/>

<ShuttleOptionsContext @ref="shuttleOptionsContext">
    <MudLayout>
        <MudAppBar Elevation="1">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
            <MudText>Shuttle</MudText>
            <MudSpacer/>
            <ShuttleOptionsButton/>
        </MudAppBar>
        <MudDrawer @bind-Open="@drawerOpen" Elevation="1">
            <MudDrawerHeader>
                <MudText Typo="Typo.h6">Shuttle</MudText>
            </MudDrawerHeader>
            <ShuttleNavMenu/>
        </MudDrawer>
        <MudMainContent>
            @Body
        </MudMainContent>
    </MudLayout>
</ShuttleOptionsContext>

@code{
    private bool drawerOpen = false;

    private void ToggleDrawer()
    {
        drawerOpen = !drawerOpen;
    }
}
