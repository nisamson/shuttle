@using Shuttle.WebClient.Components
@using Shuttle.WebClient.Components.Dev
@using Shuttle.WebClient.Components.Options
@inherits LayoutComponentBase

<ShuttleOptionsContext OptionsChanged="OnOptionsChanged">
    <FluentLayout>
        <FluentLayoutItem Area="LayoutArea.Header">
            <div style="position: relative;">
                <FluentStack VerticalAlignment="VerticalAlignment.Center">
                    <FluentLayoutHamburger/>
                    <FluentSpacer/>
                    <ShuttleLogo/>
                    <span class="app-title" style="font-weight: 600; font-size: 1.5rem; line-height: 1; margin-inline-start: 0.5rem;">Shuttle</span>
                    <FluentSpacer/>
                    <FeedbackButton/>
                    <ShuttleOptionsButton/>
                </FluentStack>
                <PendingRequestIndicator/>
            </div>
        </FluentLayoutItem>
        <FluentLayoutItem Area="LayoutArea.Navigation"
                          Width="@(NavCollapsed ? "48px" : "250px")"
                          Class="@(NavCollapsed ? "nav-rail" : null)">
            <div class="nav-shell">
                <div class="nav-toggle-bar">
                    <FluentButton Class="nav-toggle-desktop"
                                  Appearance="ButtonAppearance.Transparent"
                                  Title="Toggle navigation"
                                  aria-label="Toggle navigation"
                                  OnClick="ToggleNav">
                        <FluentIcon Value="@(new Icons.Regular.Size24.Navigation())"/>
                    </FluentButton>
                </div>
                <div class="nav-scroll">
                    <ShuttleNavMenu/>
                </div>
            </div>
        </FluentLayoutItem>
        <FluentLayoutItem Area="LayoutArea.Content" Padding="@Padding.All3">
            <div class="content">
                @Body
            </div>
        </FluentLayoutItem>
    </FluentLayout>
</ShuttleOptionsContext>

<FluentProviders/>

