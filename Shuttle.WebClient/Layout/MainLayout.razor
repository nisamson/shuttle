@using Shuttle.WebClient.Components
@using Shuttle.WebClient.Components.Dev
@using Shuttle.WebClient.Components.Options
@inherits LayoutComponentBase

<FluentDesignTheme Mode="@(Options.DarkMode ? DesignThemeModes.Dark : DesignThemeModes.Light)"/>

<ShuttleOptionsContext OptionsChanged="OnOptionsChanged">
    <FluentLayout>
        <FluentHeader>
            <FluentButton Appearance="Appearance.Stealth" OnClick="@ToggleDrawer" Title="Toggle navigation">
                <FluentIcon Value="@(new Icons.Regular.Size24.Navigation())" Color="Color.Fill"/>
            </FluentButton>
            <span class="app-title">Shuttle</span>
            <FluentSpacer/>
            <ShuttleOptionsButton/>
        </FluentHeader>
        <FluentStack Class="main" Orientation="Orientation.Horizontal" Width="100%">
            <ShuttleNavMenu Expanded="@drawerOpen"/>
            <FluentBodyContent Class="body-content">
                <div class="content">
                    @Body
                </div>
            </FluentBodyContent>
        </FluentStack>
    </FluentLayout>
</ShuttleOptionsContext>

<FluentToastProvider/>
<FluentDialogProvider/>
<FluentTooltipProvider/>
<FluentMessageBarProvider/>
<FluentMenuProvider/>

@code{
    private bool drawerOpen = true;

    private void ToggleDrawer()
    {
        drawerOpen = !drawerOpen;
    }
}
