@implements Microsoft.FluentUI.AspNetCore.Components.IDialogContentComponent<Shuttle.WebClient.Models.Options.ShuttleOptions>

<FluentDialogBody>
    <FluentSwitch @bind-Value="OptionsModel.DarkMode" Label="Use Dark Mode"/>
    <FluentStack HorizontalAlignment="HorizontalAlignment.End" Style="margin-top: 1rem;">
        <FluentButton Appearance="Appearance.Neutral" OnClick="OnCancelEdit">Cancel</FluentButton>
        <FluentButton Appearance="Appearance.Accent" Disabled="@(!IsTouched)" OnClick="OnOptionsEdited">Save</FluentButton>
    </FluentStack>
</FluentDialogBody>